<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- location lane (DESIGN_V3 §5): publishing a mock GPS fix that matches the proxy exit geo.
         NOTE: the mock-location test-provider API (addTestProvider/setTestProviderLocation, Fused
         setMockMode) is gated by the Developer-Options "mock location app" app-op, NOT by the
         ACCESS_*_LOCATION runtime permissions — and nothing in the app reads the real device
         location — so those dangerous grants are deliberately NOT declared (Play-review + privacy).
         ACCESS_MOCK_LOCATION is the ONE exception: it is a signature/system-only permission that is
         never actually GRANTED to a normal app, but its mere DECLARATION is what makes DJProxy appear
         in Settings -> Developer options -> "Select mock location app" (the picker enumerates only
         packages that declare it). That developer-options selection — not this permission — is what
         authorizes addTestProvider/setTestProviderLocation. tools:ignore silences the expected
         MockLocation/ProtectedPermissions lint (this is intentional and the whole mock-location fix). -->
    <uses-permission
        android:name="android.permission.ACCESS_MOCK_LOCATION"
        tools:ignore="MockLocation,ProtectedPermissions" />

    <!-- hotspot lane (DESIGN_V3 §6): discovering the hotspot/LAN interface IP to bind LanShareServer,
         and (API 33+) enumerating nearby Wi-Fi without also requiring location permission. The app
         never toggles Wi-Fi/tethering, so CHANGE_WIFI_STATE is intentionally omitted. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="33" />

    <!-- qr lane (DESIGN_V4 §platform-8): CameraX-backed QR scanner (import lane) + encoder
         (hotspot ShareLan). android.hardware.camera is declared non-required so this remains a
         universal build for camera-less devices/emulators; CameraPermission.kt gates the runtime
         grant before QrCameraScanner ever binds a CameraX session. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!--
      vpngate-v2 lane (platform seam): package-visibility declaration (targetSdk 35 / API 30+). The
      one-tap "Connect (open in VPN app)" hand-off in VpnGateController.connectOvpn calls
      queryIntentActivities/resolveActivity to (a) exclude DJProxy's own self-registration from the
      chooser and (b) detect whether ANY external OpenVPN app can handle
      application/x-openvpn-profile so it can show install-guidance when none exists. Without this
      <queries>, on API 30+ the query returns empty and DJProxy would wrongly report "no app
      installed". The launch itself still works via ActivityNotFoundException-guarded startActivity;
      this block only fixes the presence-check that drives the guidance copy.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/x-openvpn-profile" />
        </intent>
    </queries>

    <application
        android:name=".DjProxyApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DJProxy">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:resizeableActivity="true"
            android:theme="@style/Theme.DJProxy.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              ui seam §7 / config seam: djproxy://import|connect deep links (BROWSABLE), consumed by
              MainActivity -> viewModel.ingestExternal(raw, autoConnect). A custom scheme needs no
              android:autoVerify / Digital Asset Links, unlike https app links.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="djproxy" android:host="import" />
                <data android:scheme="djproxy" android:host="connect" />
            </intent-filter>

            <!--
              config seam: bare socks5:// / ss:// (SIP002) URIs opened from a browser, file manager,
              or another app's "open with" chooser. Routed through the same ingestExternal path.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="socks5" />
                <data android:scheme="ss" />
            </intent-filter>

            <!--
              platform §8: share-target for a config URI or subscription link shared as plain text
              from another app (browser share sheet, messaging app, etc). MainActivity reads
              EXTRA_TEXT and forwards to ingestExternal(raw, autoConnect = false) — never
              auto-connects from an untrusted SEND without a confirmation tap per the consent gate.
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!--
              config seam / OvpnParser: opening a .ovpn file (content:// from a document provider,
              or file:// from a legacy file manager). DJProxy is a SOCKS/HTTP proxy app, not an
              OpenVPN client — OvpnParser extracts only 'http-proxy'/'socks-proxy'/'remote' directives
              and honestly rejects files with no proxy directive.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/x-openvpn-profile" />
                <data android:scheme="file" android:mimeType="application/x-openvpn-profile" />
                <data android:scheme="file" android:pathPattern=".*\\.ovpn" />
                <data android:scheme="content" android:pathPattern=".*\\.ovpn" />
            </intent-filter>
        </activity>

        <service
            android:name=".vpn.DjVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Device-wide proxy tunnel" />
        </service>

        <!--
          Native engine sidecar, isolated in its own :engine process so a native hev crash degrades
          fail-closed (routes held, nothing forwards) instead of leaking. Declaration contributed by
          the engine lane; the vpn lane owns this manifest. Implementation class: engine/EngineService.
        -->
        <service
            android:name=".engine.EngineService"
            android:exported="false"
            android:process=":engine"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Proxy tunnel packet engine" />
        </service>

        <!--
          tor lane (DESIGN_V4): embedded Tor bootstrap, run as its own foreground service so the
          Tor process survives Doze/background exactly like DjVpnService/EngineService. Exposes a
          local SOCKS5 on 127.0.0.1:9050 that TorGateway.controller.proxyConfig() feeds into the
          EXISTING VpnController.apply(ProxyConfig) — zero core edits. The vendored
          org.torproject.jni.TorService (declared inside the info.guardianproject:tor-android AAR
          itself, merged automatically) is the actual Tor daemon host; ai.darshj.djproxy.tor.TorService
          is this app's own FGS wrapper/lifecycle owner around OnionProxyManager/TorControllerImpl.
        -->
        <service
            android:name=".tor.TorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Tor onion routing" />
        </service>

        <!--
          CRASH FIX (2026-07-20): the vendored guardianproject org.torproject.jni.TorService calls
          startForeground() in its onCreate(), but the tor-android AAR declares it WITHOUT a
          foregroundServiceType. On Android 14+/targetSdk 35 that throws
          MissingForegroundServiceTypeException the instant Tor starts — "it closes the screen".
          Confirmed via the on-device crash trace (TorService.onCreate -> j). We merge a
          foregroundServiceType onto the library's service so the FGS start is valid. tools:node="merge"
          adds the attribute to the AAR's existing declaration; tools:replace guards against a
          conflicting library value.
        -->
        <service
            android:name="org.torproject.jni.TorService"
            android:foregroundServiceType="specialUse"
            tools:node="merge">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Tor onion routing"
                tools:node="merge" />
        </service>

        <!--
          surfaces lane: Quick Settings tiles. Both extend TileService (API 24+); on API 21-23 the
          android.service.quicksettings.action.QS_TILE action is simply never dispatched by the
          platform, so declaring the <service> at minSdk 21 is safe — the class itself guards any
          API 24+ call (Build.VERSION.SDK_INT checks per TileService API24+ guarded note).
        -->
        <service
            android:name=".surfaces.ConnectTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_connect"
            android:label="@string/tile_connect_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data android:name="android.service.quicksettings.ACTIVE_TILE" android:value="true" />
        </service>

        <service
            android:name=".surfaces.TorTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_tor"
            android:label="@string/tile_tor_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data android:name="android.service.quicksettings.ACTIVE_TILE" android:value="true" />
        </service>

        <!--
          surfaces lane: classic RemoteViews home-screen widget (no glance/compose-glance dep,
          minSdk21-safe). DjWidgetProvider reads VpnRuntime.state/currentConfig and the same
          DjVpnService start path via WidgetActions' PendingIntents; it never routes without prior
          VPN consent (a tap always launches MainActivity first if consent/config is missing).

          SECURITY (v4 fix): android:exported="false". onReceive() dispatches privileged VPN-control
          actions (TOGGLE / STOP / TOR_TOGGLE) — WidgetActions.stop() tears the whole tunnel down with
          NO consent gate. An exported receiver let any zero-permission app fire an explicit STOP intent
          and kill the proxy (a remote deanonymization / kill-switch bypass). The AppWidget host is a
          privileged system component and still delivers APPWIDGET_UPDATE to a non-exported provider, and
          the widget's own button PendingIntents (created by this app via getBroadcast) are delivered on
          the creator token regardless of export — so the custom actions now reach onReceive ONLY from
          our own PendingIntents, never from a foreign process.
        -->
        <receiver
            android:name=".surfaces.DjWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_djproxy_info" />
        </receiver>

        <!--
          Feature-lane wiring seam (DESIGN_V3 §9.1). Core defines FeatureRegistry holders; each
          feature lane ships its own androidx.startup Initializer (a *Registrar class in its own
          package) that sets one holder / adds one settings panel at process start, with zero edits
          to any core file. compat is the single writer of this manifest, so it is the one place
          these Initializers are registered as <meta-data> under androidx.startup's own provider.
          tools:node="merge" lets the androidx.startup library's own manifest (which declares the
          <provider> itself) merge with these app-contributed entries instead of colliding with it.
          If a lane's Registrar class does not exist yet (mid-build), androidx.startup simply will
          not find it at runtime — it does not fail the whole app; each lane is expected to ship the
          matching class in the package below.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="ai.darshj.djproxy.location.LocationRegistrar"
                android:value="androidx.startup" />
            <meta-data
                android:name="ai.darshj.djproxy.hotspot.HotspotRegistrar"
                android:value="androidx.startup" />
            <meta-data
                android:name="ai.darshj.djproxy.diag.DiagnosticsRegistrar"
                android:value="androidx.startup" />
            <meta-data
                android:name="ai.darshj.djproxy.tor.TorRegistrar"
                android:value="androidx.startup" />
            <!-- adblock lane (DESIGN_V6): builds Blocklist+AdblockController, sets the frozen-core
                 FeatureRegistry.blockedHostPredicate seam + wraps dnsResolverFactory, publishes
                 AdblockGateway.controller for the ui toggle, and adds AdblockSettingsPanel. -->
            <meta-data
                android:name="ai.darshj.djproxy.adblock.AdblockRegistrar"
                android:value="androidx.startup" />
            <!-- vpngate lane (DESIGN_V6): builds the RemoteVpnGateSource + VpnGateController, publishes
                 VpnGateGateway.controller for the Servers-screen VPN Gate tab, and adds
                 VpnGateSettingsPanel. Catalog browser + .ovpn hand-off — never its own tunnel/FGS. -->
            <meta-data
                android:name="ai.darshj.djproxy.vpngate.VpnGateRegistrar"
                android:value="androidx.startup" />
            <!-- ovpnengine lane (v9): the userspace OpenVPN->local-SOCKS5 engine (gomobile ovpnsocks.aar)
                 that lets a VPN Gate server be used AS a device-wide proxy through the existing hev
                 tunnel — same shape as the Tor lane. Publishes OvpnEngineGateway.controller. -->
            <meta-data
                android:name="ai.darshj.djproxy.ovpnengine.OvpnEngineRegistrar"
                android:value="androidx.startup" />
        </provider>

        <!--
          vpngate-v2 lane (platform seam): FileProvider that vends the app-private
          cacheDir/ovpn/<name>.ovpn file as a content:// URI so VpnGateController.connectOvpn can
          hand a VPN Gate .ovpn profile to an EXTERNAL OpenVPN app via ACTION_VIEW +
          FLAG_GRANT_READ_URI_PERMISSION. DJProxy does NOT tunnel OpenVPN itself — this is a pure
          hand-off. The authority is "${applicationId}.fileprovider"; ${applicationId} auto-appends
          the .debug build suffix (build.gradle.kts:71), matching the authority VpnGateController
          derives at runtime from context.packageName + ".fileprovider" (never hardcoded). Paths are
          declared in res/xml/file_paths.xml (cache-path ovpn/). exported=false + grantUriPermissions
          keep it a per-Intent, read-only grant — no broad export.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
