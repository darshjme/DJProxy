<?xml version="1.0" encoding="utf-8"?>
<!--
  DJProxy adaptive icon — background layer.
  Deep navy glass backdrop (matches the dark-first glassmorphism UI). Full 108x108dp bleed;
  the foreground shield + tunnel motif sits on top within the 66dp safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:startColor="#0A0F1E"
                android:centerColor="#0D1526"
                android:endColor="#131C33" />
        </aapt:attr>
    </path>

    <!-- faint radial glow in the upper-right quadrant, echoing the "light at the end" motif -->
    <path android:pathData="M84,54 a30,30 0 1,0 0.01,0 z"
        android:fillAlpha="0.12">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="84"
                android:centerY="54"
                android:gradientRadius="30"
                android:startColor="#3DD6F0"
                android:endColor="#00000000" />
        </aapt:attr>
    </path>
</vector>
