<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash lock animation, frame 6/6 — the "lock" (ring closed, glyph resolved, bloom flash).
  Final resting frame; matches splash_icon.* / DESIGN_V4 SplashHandoff end state.
  See splash_ring_lock_anim.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="240dp"
    android:height="240dp"
    android:viewportWidth="240"
    android:viewportHeight="240">

    <!-- bloom flash -->
    <path android:pathData="M120,120 m-112,0 a112,112 0 1,0 224,0 a112,112 0 1,0 -224,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="120"
                android:centerY="120"
                android:gradientRadius="112"
                android:startColor="#4622D3EE"
                android:centerColor="#1A6366F1"
                android:endColor="#006366F1" />
        </aapt:attr>
    </path>

    <!-- closed ring, full tri-tone sweep -->
    <path android:pathData="M120,42 A78,78 0 1,1 120,198 A78,78 0 1,1 120,42"
        android:fillColor="#00000000"
        android:strokeWidth="10"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="42" android:startY="42"
                android:endX="198" android:endY="198"
                android:startColor="#22D3EE"
                android:centerColor="#8B7BF5"
                android:endColor="#6366F1" />
        </aapt:attr>
    </path>

    <!-- resolved power glyph -->
    <path
        android:pathData="M120,74 A40,40 0 1,0 120.1,74"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
    <path
        android:pathData="M120,70 L120,104"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round" />
</vector>
