<?xml version="1.0" encoding="utf-8"?>
<!--
  Brand-owned fallback splash "lock" animation — a plain frame-by-frame AnimationDrawable
  (android:oneshot="true") for any surface that needs the ring-closes moment without Compose
  (e.g. a classic RemoteViews widget preview, or a pre-Compose splash frame). This does NOT
  replace ui/SplashHandoff.kt's real Compose-driven arc draw (600ms EaseOutCubic) — that stays
  the primary, smoother implementation for MainActivity's first frame. This is the offline,
  dependency-free equivalent for contexts that cannot host Compose.
  Total runtime ~600ms across 6 frames (100ms each) to match MotionTokens' LOCK_MS = 420 plus
  a settle frame, then holds on the final locked frame.
-->
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="true">
    <item android:drawable="@drawable/splash_ring_frame_1" android:duration="90" />
    <item android:drawable="@drawable/splash_ring_frame_2" android:duration="90" />
    <item android:drawable="@drawable/splash_ring_frame_3" android:duration="90" />
    <item android:drawable="@drawable/splash_ring_frame_4" android:duration="80" />
    <item android:drawable="@drawable/splash_ring_frame_5" android:duration="70" />
    <item android:drawable="@drawable/splash_ring_frame_6" android:duration="500" />
</animation-list>
