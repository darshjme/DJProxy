<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- DJProxy brand palette — dark-first glassmorphism, shield/tunnel identity.
         Shared across the XML theme here and (independently) the Compose theme in ui/theme/Color.kt. -->

    <!-- base surfaces. djp_bg matches the Compose djBackgroundBrush() outer/edge stop
         (DjColors.VoidBlack #05070A) so the window/system-bar chrome and the splash->content
         hand-off share one seamless near-black instead of jumping bluer at release. -->
    <color name="djp_bg">#05070A</color>
    <color name="djp_bg_elevated">#131C33</color>
    <color name="djp_surface_glass">#1A2340</color>
    <color name="djp_outline">#2A3654</color>

    <!-- brand accent (shield gradient endpoints) -->
    <color name="djp_accent_cyan">#22D3EE</color>
    <color name="djp_accent_indigo">#6D5CF6</color>
    <color name="djp_accent_core">#EAFCFF</color>

    <!-- semantic -->
    <color name="djp_success">#34D399</color>
    <color name="djp_warning">#FBBF24</color>
    <color name="djp_error">#F87171</color>

    <!-- text -->
    <color name="djp_text_primary">#F5F8FF</color>
    <color name="djp_text_secondary">#9AA6C4</color>

    <!-- legacy XML theme aliases -->
    <color name="colorPrimary">@color/djp_accent_cyan</color>
    <color name="colorPrimaryDark">@color/djp_bg</color>
    <color name="colorAccent">@color/djp_accent_indigo</color>

    <!-- splash screen (androidx.core.splashscreen): identical near-black surface as djp_bg
         (= DjColors.VoidBlack #05070A, the outer stop of djBackgroundBrush()), so the system
         splash releases into the Compose sequence with no visible tone shift. -->
    <color name="djp_splash_bg">#05070A</color>
</resources>
